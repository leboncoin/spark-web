{
  "name": "@spark-ui/components",
  "version": "17.5.1",
  "license": "MIT",
  "description": "Spark (Leboncoin design system) components.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./form-field": {
      "types": "./dist/src/form-field/index.d.ts",
      "import": "./dist/form-field/index.mjs",
      "require": "./dist/form-field/index.js"
    },
    "./*": {
      "types": "./dist/src/*/index.d.ts",
      "import": "./dist/*/index.mjs",
      "require": "./dist/*/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/src/*/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "@spark-ui",
    "react",
    "component",
    "accessible",
    "accessibility",
    "wai-aria",
    "aria",
    "a11y"
  ],
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=8192' vite build"
  },
  "dependencies": {
    "@base-ui/react": "1.0.0",
    "@react-aria/button": "3.13.3",
    "@react-aria/numberfield": "3.11.16",
    "@react-stately/numberfield": "3.9.13",
    "@spark-ui/hooks": "17.5.1",
    "@spark-ui/icons": "17.5.1",
    "@spark-ui/internal-utils": "17.5.1",
    "@zag-js/pagination": "1.30.0",
    "@zag-js/react": "1.30.0",
    "class-variance-authority": "0.7.1",
    "downshift": "9.0.13",
    "emulate-tab": "1.2.1",
    "motion": "12.34.5",
    "radix-ui": "1.4.3",
    "react-aria-components": "1.15.1",
    "react-snap-carousel": "0.5.1"
  },
  "peerDependencies": {
    "@spark-ui/theme-utils": "17.5.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.1.18"
  },
  "devDependencies": {
    "jsdom-testing-mocks": "1.16.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/leboncoin/spark-web.git",
    "directory": "packages/components"
  },
  "bugs": {
    "url": "https://github.com/leboncoin/spark-web/issues?q=is%3Aopen+label%3A%22Component%3A+button%22"
  },
  "homepage": "https://sparkui.vercel.app"
}
