{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "composite": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "module": "ESNext",
    "types": ["node", "vitest/globals"],
    "paths": {
      "@docs/*": ["./documentation/*"],
      "@spark-ui/components/*": ["./packages/components/src/*"],
      "@spark-ui/hooks/*": ["./packages/hooks/src/*"],
      "@spark-ui/internal-utils": ["./packages/utils/internal-utils/src"],
      "@spark-ui/internal-utils/*": ["./packages/utils/internal-utils/src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "vitest.setup.ts",
    "playwright.config.ts",
    "global.d.ts",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "e2e/**/*.ts",
    "e2e/**/*.tsx"
  ],
  "exclude": ["node_modules", "**/dist"]
}
