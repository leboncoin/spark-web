{
  "name": "spark",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "prepare": "husky install",
    "postinstall": "nx run-many -t build",
    "clean": "nx reset && find packages -type d -name dist -prune -exec rm -rf {} +",
    "build": "nx run-many -t build",
    "build:watch": "nx watch -- nx run-many -t build",
    "release": "nx release --yes",
    "release:beta": "node bin/release-beta.js --dry-run",
    "storybook:start": "storybook dev -p 6006",
    "storybook:build": "storybook build -o dist",
    "test": "vitest",
    "test:ui": "vitest watch --ui",
    "test:run": "vitest run",
    "test:coverage": "rm -rf ./dist/coverage && vitest run --coverage --coverage.provider=v8",
    "test:coverage:open": "npx open-cli ./dist/coverage/index.html",
    "test:e2e": "npx playwright install && npx playwright test --grep-invert 'should not have any accessibility issues'",
    "test:e2e:visual": "npx playwright install && npx playwright test --ui",
    "test:a11y": "npx playwright install && node e2e/a11y/run-a11y-tests.cjs",
    "typecheck": "tsc --noEmit",
    "commit": "git-cz",
    "lint": "oxlint -c .oxlintrc.json packages documentation",
    "lint:fix": "oxlint -c .oxlintrc.json packages documentation --fix",
    "lint:staged": "lint-staged --config .lintstagedrc.json",
    "format": "oxfmt \"packages/**/*.{ts,tsx,js,mjs}\" \"documentation/**/*.{ts,tsx}\"",
    "format:check": "oxfmt --check \"packages/**/*.{ts,tsx,js,mjs}\" \"documentation/**/*.{ts,tsx}\"",
    "prettify": "npm run lint && npm run format",
    "node:check": "node bin/check-node-version.js",
    "generate": "spark-generate",
    "codecov:check-yml": "cat .codecov.yml | curl --data-binary @- https://codecov.io/validate"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:leboncoin/spark-web.git"
  },
  "dependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@spark-ui/components": "*",
    "@spark-ui/theme-utils": "^10.0.11",
    "@xyflow/react": "^12.10.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@babel/core": "7.28.5",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/config-workspace-scopes": "^20.0.0",
    "@commitlint/cz-commitlint": "^20.0.0",
    "@commitlint/prompt-cli": "^20.0.0",
    "@nx/devkit": "^21.5.3",
    "@nx/js": "^21.5.3",
    "@playwright/test": "^1.58.2",
    "@spark-ui/cli-utils": "*",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-designs": "^11.1.2",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tailwindcss/postcss": "4.1.16",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.5.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "@vueless/storybook-dark-mode": "^10.0.7",
    "aria-query": "^5.3.2",
    "babel-loader": "10.0.0",
    "browserslist-to-esbuild": "2.1.1",
    "chalk": "^5.6.2",
    "class-variance-authority": "0.7.1",
    "commitizen": "4.3.1",
    "concurrently": "^9.2.1",
    "copy-to-clipboard": "3.3.3",
    "d3": "^7.9.0",
    "deepmerge": "4.3.1",
    "husky": "9.1.7",
    "jsdom": "27.1.0",
    "lint-staged": "16.2.6",
    "nx": "^21.5.3",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "postcss": "8.5.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-element-to-jsx-string": "^17.0.1",
    "react-live": "4.1.8",
    "react-router-dom": "7.13.1",
    "react-xarrows": "^2.0.2",
    "remark-gfm": "^4.0.1",
    "resize-observer-polyfill": "^1.5.1",
    "rollup": "4.59.0",
    "scroll-into-view-if-needed": "^3.1.0",
    "storybook": "^10.3.3",
    "tailwindcss": "4.1.16",
    "ts-node": "10.9.2",
    "type-fest": "5.1.0",
    "typescript": "6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.52.3",
    "@tailwindcss/oxide-linux-x64-gnu": "4.1.16",
    "lightningcss-linux-x64-gnu": "1.30.2"
  },
  "workspaces": [
    "packages/hooks",
    "packages/utils/*",
    "packages/components",
    "packages/icons"
  ],
  "browserslist": [
    "> 0.5% or > 0.1% and last 2 years, not dead, not Firefox ESR, not and_qq > 0, not and_uc > 0, not and_ff >0"
  ],
  "namespaces": [
    "spark-ui"
  ],
  "engines": {
    "node": "22.x"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  }
}
